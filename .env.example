# PostgreSQL connection for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/msm_accounting?schema=public"

# JWT signing secret (change in production)
JWT_SECRET="replace-with-a-long-random-string-in-production"

# Google OAuth client ID (same value used by frontend and backend)
GOOGLE_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# Frontend origin for CORS during local development
FRONTEND_ORIGIN="http://localhost:5173"

# Optional: set for local debugging
NODE_ENV="development"
